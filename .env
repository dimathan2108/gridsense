CASSANDRA_CLUSTER_NAME=GridSenseCluster
CASSANDRA_DC=dc1
CASSANDRA_HEAP_NEWSIZE=128M
CASSANDRA_MAX_HEAP_SIZE=512M
CASSANDRA_HOST=timeseries-db
CASSANDRA_KEYSPACE=gridsense

NEO4J_USER=neo4j
NEO4J_PASSWORD=gridsense_neo4j_password
NEO4J_URI=bolt://graph-db:7687
NEO4J_HEAP_MAX=512M

MONGO_USERNAME=gridsense
MONGO_PASSWORD=gridsense_mongo_password
MONGO_DATABASE=gridsense
MONGO_URI=mongodb://gridsense:gridsense_mongo_password@catalog-db:27017/gridsense?authSource=admin

POSTGRES_USER=gridsense
POSTGRES_PASSWORD=gridsense_postgres_password
POSTGRES_DB=gridsense
POSTGRES_HOST=billing-db
POSTGRES_PORT=5432

REDIS_PASSWORD=gridsense_redis_password
REDIS_HOST=cache
REDIS_PORT=6379
